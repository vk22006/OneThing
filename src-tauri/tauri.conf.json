{
	"$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
	"productName": "OneThing",
	"version": "1.1.4",
	"identifier": "com.kishore.onething",
	"build": {
		"frontendDist": "../build",
		"devUrl": "http://localhost:5173",
		"beforeDevCommand": "npm run dev",
		"beforeBuildCommand": "npm run build"
	},
	"app": {
		"windows": [
			{
				"title": "OneThing",
				"width": 900,
				"height": 560,
				"resizable": false,
				"fullscreen": false,
				"decorations": false,
				"center": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/logo_32x32.png",
			"icons/logo_128x128.png",
			"icons/logo_128x128@2x.png",
			"icons/logo.icns",
			"icons/logo.ico"
		]
	}
}
